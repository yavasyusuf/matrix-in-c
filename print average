#include <stdio.h>

int main() {
    int n;
    int mx[10][10];
    int sum = 0;
    int average;

    printf("Enter size: ");
    scanf("%d", &n);

    for(int i = 0; i < n; i++) {
        for(int j = 0; j < n; j++) {
            printf("Enter element [%d][%d]: ", i, j);
            scanf("%d", &mx[i][j]);
            sum = sum + mx[i][j];
        }
    }

    average = sum / (n * n);

    for(int i = 0; i < n; i++) {
        for(int j = 0; j < n; j++) {
            if(i == 0 || i == n - 1 || j == 0 || j == n - 1) {
                mx[i][j] = average;
            }
        }
    }

    printf("\nNew Matrix:\n");
    for(int i = 0; i < n; i++) {
        for(int j = 0; j < n; j++) {
            printf("%d ", mx[i][j]);
        }
        printf("\n");
    }

    printf("\nAverage = %d\n", average);

    return 0;
}
